package com.example.servicecafe.dto;

public class UpdateDoanhThuDTO {
    private Double amount;
    private String method;

    public UpdateDoanhThuDTO() {
    }

    public UpdateDoanhThuDTO(Double amount, String method) {
        this.amount = amount;
        this.method = method;
    }

    public Double getAmount() {
        return amount;
    }

    public void setAmount(Double amount) {
        this.amount = amount;
    }

    public String getMethod() {
        return method;
    }

    public void setMethod(String method) {
        this.method = method;
    }
}
